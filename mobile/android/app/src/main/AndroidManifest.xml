<?xml version="1.0" encoding="utf-8"?>
<!--
  SportMaps — android/app/src/main/AndroidManifest.xml
  Permisos y configuración para Android
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- ── PERMISOS ─────────────────────────────────────── -->

  <!-- Internet (Supabase + mapas) -->
  <uses-permission android:name="android.permission.INTERNET"/>

  <!-- Localización para el mapa -->
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

  <!-- Cámara para foto de perfil -->
  <uses-permission android:name="android.permission.CAMERA"/>

  <!-- Galería de fotos -->
  <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
  <!-- Android <13 -->
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
      android:maxSdkVersion="32"/>

  <!-- Notificaciones push (Android 13+) -->
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

  <!-- Vibración para feedback háptico -->
  <uses-permission android:name="android.permission.VIBRATE"/>

  <!-- Estado de red (banner offline) -->
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
  <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>

  <!-- ── APLICACIÓN ────────────────────────────────────── -->
  <application
      android:label="SportMaps"
      android:name="${applicationName}"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:enableOnBackInvokedCallback="true"
      android:hardwareAccelerated="true"
      android:usesCleartextTraffic="true">

    <!-- ── ACTIVITY PRINCIPAL ──────────────────────────── -->
    <activity
        android:name=".MainActivity"
        android:exported="true"
        android:launchMode="singleTop"
        android:taskAffinity=""
        android:theme="@style/LaunchTheme"
        android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
        android:hardwareAccelerated="true"
        android:windowSoftInputMode="adjustResize">

      <!-- Launcher intent -->
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>

      <!-- ── DEEP LINKS ─────────────────────────────────── -->
      <!-- sportmaps://... -->
      <intent-filter>
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data android:scheme="sportmaps"/>
      </intent-filter>

      <!-- https://sportmaps.app/... (App Links) -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data
            android:scheme="https"
            android:host="sportmaps.app"/>
      </intent-filter>

      <!-- https://sportmaps.app/s/:slug (academia pública) -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data
            android:scheme="https"
            android:host="sportmaps.app"
            android:pathPrefix="/s/"/>
      </intent-filter>

      <!-- https://sportmaps.app/event/:slug -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data
            android:scheme="https"
            android:host="sportmaps.app"
            android:pathPrefix="/event/"/>
      </intent-filter>

      <!-- https://sportmaps.app/invite?invite=UUID -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data
            android:scheme="https"
            android:host="sportmaps.app"
            android:pathPrefix="/invite"/>
      </intent-filter>

      <!-- Flutter metadata -->
      <meta-data
          android:name="io.flutter.embedding.android.NormalTheme"
          android:resource="@style/NormalTheme"/>
    </activity>

    <!-- ── NOTIFICACIONES PUSH (FCM) ──────────────────── -->
    <service
        android:name=".SmFirebaseMessagingService"
        android:exported="false">
      <intent-filter>
        <action android:name="com.google.firebase.MESSAGING_EVENT"/>
      </intent-filter>
    </service>

    <!-- Ícono de notificación personalizado -->
    <meta-data
        android:name="com.google.firebase.messaging.default_notification_icon"
        android:resource="@drawable/ic_notification"/>

    <meta-data
        android:name="com.google.firebase.messaging.default_notification_color"
        android:resource="@color/sportmaps_green"/>

    <!-- ── QUERIES (Android 11+) ─────────────────────── -->
    <!-- Para abrir URLs de mapas, browsers, etc. -->
  </application>

  <!-- Requerir OpenGL ES 2.0 -->
  <uses-feature
      android:glEsVersion="0x00020000"
      android:required="true"/>

</manifest>
