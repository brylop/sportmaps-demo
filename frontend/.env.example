# ===========================================
# SportMaps — Variables de Entorno
# ===========================================
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local a Git.

# --- Supabase (obligatorio) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui

# --- Wompi (Colombia) ---
VITE_WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxx
# NOTA: WOMPI_INTEGRITY_SECRET NUNCA va aquí.
# Debe vivir SOLO en las variables de entorno de las Edge Functions (Supabase secrets).

# --- Sentry (Observabilidad) ---
VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxxx
VITE_SENTRY_ENVIRONMENT=development

# --- Aplicación ---
VITE_APP_NAME=SportMaps
VITE_APP_URL=http://localhost:5173
